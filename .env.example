# Green API
GREEN_API_ID=your_instance_id
GREEN_API_TOKEN=your_api_token
GROUP_CHAT_ID=123456789@g.us
MY_NUMBER=222000000000@c.us

# Serveur
PORT=3000

# Base de données PostgreSQL (Render)
DATABASE_URL=postgresql://user:password@host:5432/db

# Google Cloud Vision (fallback OCR — laisser FALLBACK_PROVIDER=none si pas de clé)
FALLBACK_PROVIDER=none
FALLBACK_API_KEY=your_google_api_key_if_you_have_one

# Rapport mensuel PDF (numéro destinataire)
REPORT_PHONE=22241355451@c.us

# URL public de l'app Render (pour le rapport PDF)
RENDER_URL=https://your-app.onrender.com

# Clé secrète pour les endpoints internes (rapport PDF)
CRON_SECRET=choose_a_random_secret

# Rétention des images en jours
IMAGE_RETENTION_DAYS=30
